@model List<TaskModel>

@{
    ViewData["Title"] = "Tasks";
    var hasTasks = Model != null && Model.Any();
}

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1 text-white">Your Tasks</h1>
        <p class="text-muted mb-0">Stay on top of what matters today.</p>
    </div>
    <div class="mt-3 mt-lg-0">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTaskModal">
            + Add Task
        </button>
    </div>
</div>

@if (!hasTasks)
{
    <div class="empty-state">
        <div class="empty-state-icon">✨</div>
        <h2 class="h5 text-white mb-2">No tasks yet</h2>
        <p class="mb-3">Create your first task and start organizing your work like a pro.</p>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTaskModal">
            Create your first task
        </button>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var task in Model)
        {
            var isOverdue = !task.IsCompleted && task.DueDate.Date < DateTime.UtcNow.Date;
            <div class="col-12 col-md-6 col-xl-4">
                <div class="task-card h-100 p-3 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h2 class="h6 task-card-title mb-0 text-white">@task.Name</h2>
                        <span class="badge rounded-pill @(task.IsCompleted ? "badge-status-completed" : (isOverdue ? "badge-status-overdue" : "badge-status-pending"))">
                            @(task.IsCompleted ? "Completed" : isOverdue ? "Overdue" : "In progress")
                        </span>
                    </div>
                    <p class="task-card-meta mb-2">
                        @task.Description
                    </p>
                    <div class="task-card-meta mb-3">
                        <span>Due: @task.DueDate.ToShortDateString()</span>
                    </div>
                    <div class="mt-auto d-flex justify-content-between gap-2">
                        <button class="btn btn-sm btn-outline-light" onclick="showDetails('@task.Id')">Details</button>
                        <button class="btn btn-sm btn-outline-primary" onclick="showEdit('@task.Id')">Edit</button>
                        <a href="@Url.Action("Delete", "Task", new { id = task.Id })"
                           class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Are you sure you want to delete this task?');">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Add Task Modal -->
<div class="modal fade" id="addTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-action="SaveNew" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div asp-validation-summary="All" class="text-danger mb-2"></div>
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input name="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="Description" class="form-control" rows="3" required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Due Date</label>
                    <input type="date" name="DueDate" class="form-control" required />
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" name="IsCompleted" id="addIsCompleted" />
                    <label class="form-check-label" for="addIsCompleted">Mark as completed</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Create Task</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="detailsBody"></div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-action="Edit" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId" name="Id" />
                <div class="mb-3">
                    <label for="editName" class="form-label">Title</label>
                    <input type="text" class="form-control" id="editName" name="Name" required />
                </div>
                <div class="mb-3">
                    <label for="editDescription" class="form-label">Description</label>
                    <textarea class="form-control" id="editDescription" name="Description" required></textarea>
                </div>
                <div class="mb-3">
                    <label for="editDueDate" class="form-label">Due Date</label>
                    <input type="date" class="form-control" id="editDueDate" name="DueDate" required />
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="editIsCompleted" name="IsCompleted" />
                    <label class="form-check-label" for="editIsCompleted">Completed</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showDetails(id) {
            fetch('/Task/GetTask?id=' + id)
                .then(res => res.json())
                .then(task => {
                    document.getElementById('detailsTitle').innerText = task.Name;
                    document.getElementById('detailsBody').innerHTML =
                        `<p><strong>Description:</strong> ${task.Description}</p>
                         <p><strong>Due Date:</strong> ${new Date(task.DueDate).toLocaleDateString()}</p>
                         <p><strong>Status:</strong> ${task.IsCompleted ? "Completed" : "Pending"}</p>`;
                    new bootstrap.Modal(document.getElementById('detailsModal')).show();
                });
        }

        function showEdit(id) {
            fetch('/Task/GetTask?id=' + id)
                .then(res => res.json())
                .then(task => {
                    document.getElementById('editId').value = task.Id;
                    document.getElementById('editName').value = task.Name;
                    document.getElementById('editDescription').value = task.Description;
                    document.getElementById('editDueDate').value = task.DueDate.split('T')[0];
                    document.getElementById('editIsCompleted').checked = task.IsCompleted;
                    new bootstrap.Modal(document.getElementById('editModal')).show();
                });
        }
    </script>
}

