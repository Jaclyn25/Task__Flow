@{
    ViewData["Title"] = "Privacy Policy";
}
<div class="row">
    <div class="col-12 col-lg-8">
        <h1 class="h3 mb-3" style="color: #1f2937; font-weight: 800;">@ViewData["Title"]</h1>
        <p class="text-muted mb-4" style="color: #6b7280; font-weight: 400;">
            We care deeply about how your data is collected, used, and stored in TaskFlow.
            This page explains, in simple language, what we do and what we never do.
        </p>

        <h2 class="h5 mt-3 mb-2" style="color: #1f2937; font-weight: 700; letter-spacing: -0.3px;">What we store</h2>
        <ul class="text-muted">
            <li>Basic account information such as your name and email address.</li>
            <li>Tasks you create, including title, description, due date, and completion status.</li>
            <li>Technical metadata required to keep your account secure and the app running.</li>
        </ul>

        <h2 class="h5 mt-4 mb-2" style="color: #1f2937; font-weight: 700; letter-spacing: -0.3px;">What we never do</h2>
        <ul class="text-muted" style="color: #6b7280;">
            <li>We do not sell your personal data to third parties.</li>
            <li>We do not access your tasks content unless you explicitly ask for support.</li>
            <li>We do not use your data to show ads inside TaskFlow.</li>
        </ul>

        <h2 class="h5 mt-4 mb-2" style="color: #1f2937; font-weight: 700; letter-spacing: -0.3px;">How we use your data</h2>
        <p class="text-muted" style="color: #6b7280;">
            Your data is used exclusively to provide and improve the TaskFlow service, such as:
            syncing tasks between sessions, remembering your preferences, and ensuring that only
            you can access your workspace.
        </p>

        <h2 class="h5 mt-4 mb-2" style="color: #1f2937; font-weight: 700; letter-spacing: -0.3px;">Your controls</h2>
        <p class="text-muted mb-0" style="color: #6b7280;">
            You can always edit or delete tasks from your dashboard. If you would like your account
            and all associated data to be removed, please contact support and we will handle the request.
        </p>
    </div>
</div>
